        "# 4. 오케스트 레이어 설정\n",
        "\n",
        "def multi_agent_insurance_medical_demo(question: str):\n",
        "    print(\"1) 보험정보 에이전트 검색 중...\")\n",
        "    insurance_result = insurance_web_agent(question)\n",
        "    print(\"\\n[보험정보 에이전트 결과]\")\n",
        "    print(insurance_result[\"text\"])\n",
        "\n",
        "    print(\"\\n2) 의료정보 에이전트 검색 중...\")\n",
        "    medical_result = medical_web_agent(question)\n",
        "    print(\"\\n[의료정보 에이전트 결과]\")\n",
        "    print(medical_result[\"text\"])\n",
        "\n",
        "    print_sources(\"보험정보\", insurance_result[\"sources\"])\n",
        "    print_sources(\"의료정보\", medical_result[\"sources\"])\n",
        "\n",
        "    print(\"\\n3) 취합 에이전트 정리 중...\")\n",
        "    final_answer = call_synthesis_agent(\n",
        "        user_question=question,\n",
        "        insurance_result=insurance_result,\n",
        "        medical_result=medical_result\n",
        "    )\n",
        "\n",
        "    print(\"\\n==============================\")\n",
        "    print(\"최종 취합 결과\")\n",
        "    print(\"==============================\")\n",
        "    print(final_answer)\n",
