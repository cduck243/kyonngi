        "# 시스템에 설치된 한글 폰트 후보 찾기\n",
        "font_candidates = []\n",
        "for keyword in [\"Nanum\", \"Noto Sans CJK\", \"Noto Serif CJK\", \"UnDotum\", \"Baekmuk\"]:\n",
        "    try:\n",
        "        result = subprocess.check_output(f\"fc-list | grep '{keyword}'\", shell=True).decode(\"utf-8\")\n",
        "        lines = [line for line in result.split(\"\\n\") if line.strip()]\n",
        "        font_candidates.extend(lines)\n",
        "    except:\n",
        "        pass\n",
        "\n",
        "print(\"=== 발견된 폰트 후보 ===\")\n",
        "for f in font_candidates[:20]:\n",
        "    print(f)\n",
        "\n",
        "# 실제 사용할 폰트 파일 선택\n",
        "font_path = None\n",
        "\n",
        "preferred_paths = [\n",
        "    \"/usr/share/fonts/truetype/nanum/NanumGothic.ttf\",\n",
        "    \"/usr/share/fonts/truetype/nanum/NanumBarunGothic.ttf\",\n",
        "]\n",
        "\n",
        "for p in preferred_paths:\n",
        "    if os.path.exists(p):\n",
        "        font_path = p\n",
        "        break\n",
        "\n",
        "# 제외처리\n",
        "if font_path is None and font_candidates:\n",
        "    font_path = font_candidates[0].split(\":\")[0]\n",
        "\n",
        "print(\"\\n선택된 폰트 경로:\", font_path)\n",
        "\n",
        "# 강제 폰트 등록\n",
        "if font_path is not None:\n",
        "    fm.fontManager.addfont(font_path)\n",
        "    font_prop = fm.FontProperties(fname=font_path)\n",
        "    font_name = font_prop.get_name()\n",
        "    print(\"적용 폰트 이름:\", font_name)\n",
