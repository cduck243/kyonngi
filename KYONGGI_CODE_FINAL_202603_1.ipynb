        "# BLIP 오픈소스로 이미지에 캡션 생성하기\n",
        "\n",
        "# 1. 라이브러리 설치\n",
        "!pip install -q transformers pillow torch\n",
        "import os\n",
        "import torch\n",
        "from transformers import BlipProcessor, BlipForConditionalGeneration\n",
        "from PIL import Image\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 드라이브 다시 마운트하기\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "\n",
        "# 2. 이미지 로드하기\n",
        "BASE_DIR = \"/content/drive/MyDrive/KYONGGI_SMEAI\"\n",
        "image_files = [\n",
        "    \"IMG1.png\",\n",
        "    \"IMG2.png\",\n",
        "    \"IMG3.png\",\n",
        "    \"IMG4.png\",\n",
        "    \"IMG5.png\",\n",
        "    \"IMG6.png\",\n",
        "]\n",
        "image_paths = [os.path.join(BASE_DIR, f) for f in image_files]\n",
        "image_paths\n",
        "\n",
        "\n",
        "# 3. BLIP 모델로드 하기\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(\"사용 디바이스:\", device)\n",
        "processor = BlipProcessor.from_pretrained(\"Salesforce/blip-image-captioning-base\")\n",
        "model = BlipForConditionalGeneration.from_pretrained(\n",
        "    \"Salesforce/blip-image-captioning-base\"\n",
        ").to(device)\n",
        "\n",
        "# 4. 이미지 캡션 생성 및 시각화\n",
        "def generate_caption(image_path: str) -> str:\n",
        "    \"\"\"하나의 이미지에 대해 캡션 한 줄 생성\"\"\"\n",
        "    img = Image.open(image_path).convert(\"RGB\")\n",
        "    inputs = processor(images=img, return_tensors=\"pt\").to(device)\n",
        "    with torch.no_grad():\n",
        "        output_ids = model.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=20,   # 캡션 길이 조절\n",
        "            num_beams=5          # 빔서치(조금 더 안정적인 문장)\n",
        "        )\n",
        "    caption = processor.decode(output_ids[0], skip_special_tokens=True)\n",
        "    return img, caption\n",
        "\n",
        "# 이미지에 대해 순서대로 캡션 생성\n",
        "results = []\n",
        "for p in image_paths:\n",
        "    img, cap = generate_caption(p)\n",
        "    results.append((os.path.basename(p), img, cap))\n",
        "\n",
        "# 이미지 판단 결과 시각화\n",
        "for name, img, cap in results:\n",
        "    plt.figure(figsize=(5,4))\n",
        "    plt.imshow(img)\n",
        "    plt.axis(\"off\")\n",
        "    plt.title(f\"{name}\\n{cap}\", fontsize=10)\n",
        "    plt.show()\n",
        "    print(f\"[{name}]  caption: {cap}\")\n",
        "    print(\"-\" * 60)\n",
        "\n"
      ]
