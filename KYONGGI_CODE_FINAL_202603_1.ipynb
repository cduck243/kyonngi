        "#1. 어탠션 실습하기\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# 1. 단어 사전 만들기\n",
        "vocab = [\"나\", \"는\", \"오늘\", \"서울\", \"핀테크\", \"아카데미\", \"에\", \"갔다\"]\n",
        "stoi = {w: i for i, w in enumerate(vocab)}   # string → index\n",
        "itos = {i: w for w, i in stoi.items()}       # index → string\n",
        "\n",
        "# 2. 예시 문장 입력\n",
        "sentence = [\"나\", \"는\", \"오늘\", \"서울\", \"핀테크\", \"아카데미\", \"에\", \"갔다\"]\n",
        "ids = torch.tensor([stoi[w] for w in sentence])   # (seq_len,)\n",
        "\n",
        "print(\"문장:\", sentence)\n",
        "print(\"토큰 ID:\", ids.tolist())\n",
        "\n",
        "# 2. 임베딩 (word → vector)\n",
        "d_model = 8   # 임베딩 차원\n",
        "embedding = torch.nn.Embedding(len(vocab), d_model)\n",
        "x = embedding(ids)\n",
        "print(\"\\n임베딩 shape:\", x.shape)\n",
        "\n",
        "\n",
        "# 3. Q, K, V 만들기 (Self-Attention 기본)\n",
        "W_Q = torch.nn.Linear(d_model, d_model, bias=False)\n",
        "W_K = torch.nn.Linear(d_model, d_model, bias=False)\n",
        "W_V = torch.nn.Linear(d_model, d_model, bias=False)\n",
        "\n",
        "Q = W_Q(x)\n",
        "K = W_K(x)\n",
        "V = W_V(x)\n",
        "\n",
        "# 4. Scaled Dot-Product Attention\n",
        "scores = Q @ K.T / (d_model ** 0.5)   # (6 × 6)\n",
        "attn_weights = F.softmax(scores, dim=-1)\n",
        "attn_output = attn_weights @ V\n",
        "\n",
        "print(\"\\n[어텐션 score 행렬 (원 점수)]\")\n",
        "print(scores)\n",
        "\n",
        "print(\"\\n[어텐션 weight 행렬 (softmax 후 확률)]\")\n",
        "print(attn_weights)\n",
        "\n",
        "# 5. 단어별로 어탠션 분석\n",
        "print(\"\\n============== 단어별 어텐션 해석 ==============\")\n",
        "for i, qword in enumerate(sentence):\n",
        "    print(f\"\\n🔎 '{qword}'(이)가 문장을 바라보는 시선:\")\n",
        "    for j, kword in enumerate(sentence):\n",
        "        print(f\"   {qword:>4s} → {kword:<4s}:  {attn_weights[i, j].item():.3f}\")\n"
      ]
    },
