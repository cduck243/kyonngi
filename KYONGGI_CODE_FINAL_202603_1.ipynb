      "source": [
        "# 시각화 요소 가미하기\n",
        "\n",
        "from IPython.display import display, HTML\n",
        "import html\n",
        "\n",
        "def nl2br(text):\n",
        "    return html.escape(text).replace(\"\\n\", \"<br>\")\n",
        "\n",
        "def render_sources_html(sources):\n",
        "    if not sources:\n",
        "        return \"<li>출처 없음</li>\"\n",
        "\n",
        "    items = []\n",
        "    for s in sources[:5]:\n",
        "        title = html.escape(s.get(\"title\", \"제목 없음\"))\n",
        "        url = html.escape(s.get(\"url\", \"\"))\n",
        "        if url:\n",
        "            items.append(f'<li><a href=\"{url}\" target=\"_blank\">{title}</a></li>')\n",
        "        else:\n",
        "            items.append(f\"<li>{title}</li>\")\n",
        "\n",
        "    return \"\".join(items)\n",
        "\n",
        "def show_pretty_result_from_result(question, result):\n",
        "    insurance = result[\"insurance_result\"]\n",
        "    medical = result[\"medical_result\"]\n",
        "    final = result[\"final_answer\"]\n",
        "\n",
        "    html_content = f\"\"\"\n",
        "    <div style=\"font-family: Arial, sans-serif; max-width: 1100px; margin: auto; line-height: 1.6;\">\n",
        "\n",
        "        <div style=\"\n",
        "            background: #1f2937;\n",
        "            color: white;\n",
        "            padding: 18px;\n",
        "            border-radius: 14px;\n",
        "            margin-bottom: 16px;\">\n",
        "            <h2 style=\"margin: 0 0 8px 0;\">AI 멀티 에이전트 결과</h2>\n",
        "            <div><b>질문:</b> {html.escape(question)}</div>\n",
        "        </div>\n",
        "\n",
        "        <div style=\"display: flex; gap: 14px; flex-wrap: wrap;\">\n",
        "\n",
        "            <div style=\"\n",
        "                flex: 1;\n",
        "                min-width: 320px;\n",
        "                background: #eef6ff;\n",
        "                padding: 16px;\n",
        "                border-radius: 14px;\n",
        "                border: 1px solid #dbeafe;\">\n",
        "                <h3 style=\"margin-top: 0;\">보험정보 에이전트</h3>\n",
        "                <div style=\"background: white; padding: 12px; border-radius: 10px; margin-bottom: 10px;\">\n",
        "                    {nl2br(insurance[\"text\"])}\n",
        "                </div>\n",
        "                <b>참고 출처</b>\n",
        "                <ul>\n",
        "                    {render_sources_html(insurance[\"sources\"])}\n",
        "                </ul>\n",
        "            </div>\n",
        "\n",
        "            <div style=\"\n",
        "                flex: 1;\n",
        "                min-width: 320px;\n",
        "                background: #eefdf3;\n",
        "                padding: 16px;\n",
        "                border-radius: 14px;\n",
        "                border: 1px solid #d1fae5;\">\n",
        "                <h3 style=\"margin-top: 0;\">의료정보 에이전트</h3>\n",
        "                <div style=\"background: white; padding: 12px; border-radius: 10px; margin-bottom: 10px;\">\n",
        "                    {nl2br(medical[\"text\"])}\n",
        "                </div>\n",
        "                <b>참고 출처</b>\n",
        "                <ul>\n",
        "                    {render_sources_html(medical[\"sources\"])}\n",
        "                </ul>\n",
        "            </div>\n",
        "\n",
        "        </div>\n",
        "\n",
        "        <div style=\"\n",
        "            margin-top: 16px;\n",
        "            background: #fff8e8;\n",
        "            padding: 16px;\n",
        "            border-radius: 14px;\n",
        "            border: 1px solid #fde68a;\">\n",
        "            <h3 style=\"margin-top: 0;\">최종 취합 결과</h3>\n",
        "            <div style=\"background: white; padding: 12px; border-radius: 10px;\">\n",
        "                {nl2br(final)}\n",
        "            </div>\n",
        "        </div>\n",
        "\n",
