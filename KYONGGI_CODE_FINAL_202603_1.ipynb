        "# 2. 공통 함수 설정\n",
        "def extract_sources(resp):\n",
        "    \"\"\"\n",
        "    responses.create() 결과에서 검색 소스 URL/제목을 최대한 안전하게 추출\n",
        "    \"\"\"\n",
        "    items = []\n",
        "\n",
        "    try:\n",
        "        data = resp.model_dump()\n",
        "    except Exception:\n",
        "        return items\n",
        "\n",
        "    for output_item in data.get(\"output\", []):\n",
        "        if output_item.get(\"type\") == \"web_search_call\":\n",
        "            action = output_item.get(\"action\") or {}\n",
        "            # Ensure 'sources' is a list, even if it's explicitly None in 'action'\n",
        "            sources_list = action.get(\"sources\") or []\n",
        "            for s in sources_list:\n",
        "                title = s.get(\"title\", \"\")\n",
        "                url = s.get(\"url\", \"\")\n",
        "                if title or url:\n",
        "                    items.append({\"title\": title, \"url\": url})\n",
        "\n",
        "    # 중복 제거\n",
        "    seen = set()\n",
        "    deduped = []\n",
        "    for x in items:\n",
        "        key = (x.get(\"title\", \"\"), x.get(\"url\", \"\"))\n",
        "        if key not in seen:\n",
        "            seen.add(key)\n",
        "            deduped.append(x)\n",
        "\n",
        "    return deduped\n",
        "\n",
        "\n",
        "# 웹 에이전트 설정\n",
        "def call_web_search_agent(\n",
        "    *,\n",
        "    question: str,\n",
        "    system_instruction: str,\n",
        "    allowed_domains=None,\n",
        "    model=\"gpt-5\"\n",
        "):\n",
        "    \"\"\"\n",
        "    웹검색 기반 에이전트 호출\n",
        "    - tool_choice='required'로 검색을 강제\n",
        "    - include로 검색 소스 목록 포함\n",
        "    \"\"\"\n",
        "    tool = {\"type\": \"web_search\"}\n",
        "\n",
        "    if allowed_domains:\n",
        "        tool[\"filters\"] = {\"allowed_domains\": allowed_domains}\n",
        "\n",
        "    resp = client.responses.create(\n",
        "        model=model,\n",
        "        reasoning={\"effort\": \"low\"},\n",
        "        tools=[tool],\n",
        "        tool_choice=\"required\",\n",
        "        include=[\"web_search_call.action.sources\"],\n",
        "        input=[\n",
        "            {\n",
        "                \"role\": \"system\",\n",
        "                \"content\": system_instruction\n",
        "            },\n",
        "            {\n",
        "                \"role\": \"user\",\n",
        "                \"content\": question\n",
        "            }\n",
        "        ]\n",
        "    )\n",
        "\n",
        "    return {\n",
        "        \"text\": resp.output_text,\n",
        "        \"sources\": extract_sources(resp),\n",
        "        \"raw_response\": resp\n",
        "    }\n",
        "\n",
        "# 최종 에이전트 설정\n",
        "\n",
        "def call_synthesis_agent(\n",
        "    *,\n",
        "    user_question: str,\n",
        "    insurance_result: dict,\n",
        "    medical_result: dict,\n",
        "    model=\"gpt-5\"\n",
