        "# 단순 예측하기 (나이 → 계약건수 예측)\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 예시 데이터\n",
        "x = np.array([20, 25, 30, 35, 40, 45, 50])\n",
        "y = np.array([2, 3, 4, 5, 6, 7, 8])\n",
        "\n",
        "# 평균 계산\n",
        "x_mean = np.mean(x)\n",
        "y_mean = np.mean(y)\n",
        "\n",
        "# 기울기(a)와 절편(b) 계산 (단순 선형회귀 공식)\n",
        "a = np.sum((x - x_mean) * (y - y_mean)) / np.sum((x - x_mean) ** 2)\n",
        "b = y_mean - a * x_mean\n",
        "\n",
        "print(\"기울기 a =\", round(a, 3))\n",
        "print(\"절편 b =\", round(b, 3))\n",
        "\n",
        "# 예측 (새로운 나이에 대한 계약건수)\n",
        "x_new = np.array([60, 70])\n",
        "y_pred = a * x_new + b\n",
        "print(\"예측 결과:\", y_pred)\n",
        "\n",
        "# 시각화\n",
        "plt.figure(figsize=(8, 5))\n",
        "plt.scatter(x, y, color='blue', label='실제 데이터')\n",
        "plt.plot(x, a * x + b, color='red', label='회귀선 (y = a*x + b)')\n",
        "plt.scatter(x_new, y_pred, color='green', marker='x', s=100, label='예측값')\n",
        "\n",
        "plt.title(\"단순 선형회귀 예시: 나이에 따른 계약건수 예측\", fontsize=13)\n",
        "plt.xlabel(\"나이\")\n",
        "plt.ylabel(\"계약건수\")\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()"
      ]
    },
